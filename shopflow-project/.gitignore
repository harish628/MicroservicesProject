# .gitignore (place this at shopflow-project/ root)
#
# What this file does:
# Tells git which files/folders to NEVER track, no matter how many times
# you run `git add .`. This is the single most important file for keeping
# a multi-service repo fast and small.
#
# Feynman version:
# Think of git like a moving company that catalogs every single item in
# your house before the move. node_modules is like a giant pile of free
# newspapers and flyers that accumulated in your garage — useless to move,
# easy to regenerate (just call the newspaper company again / run npm install),
# and if the movers try to catalog every single page of every flyer, the
# whole move grinds to a halt. .gitignore tells the movers "skip that pile
# entirely, don't even look at it."

# ── Node.js (order-service, notification-service, api-gateway, frontend, admin-dashboard) ──
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.npm

# ── Build outputs (regenerated by npm run build / ng build) ──
dist/
build/
.angular/
*.tsbuildinfo

# ── Python (product-service, payment-service) ──
__pycache__/
*.py[cod]
*.egg-info/
.pytest_cache/
venv/
.venv/

# ── Go (auth-service) ──
# Compiled binaries — these get rebuilt by `go build`, never commit them
auth-service/auth-service
*.exe

# ── Environment files — NEVER commit secrets ──
# .env
# .env.*
# !.env.example

# ── OS junk files ──
.DS_Store
Thumbs.db

# ── Editor/IDE folders ──
.vscode/
.idea/

# ── Logs ──
*.log

# ── Docker (added in this phase) ──
# (Dockerfiles themselves ARE tracked — only ignore things Docker generates)


