# .env (place this at shopflow-project/ root, next to docker-compose.yml)
#
# What this file does:
# docker-compose.yml reads values from THIS file automatically — anywhere
# you see ${SOMETHING} in docker-compose.yml, Compose looks here first.
#
# Feynman version: this is the one shared notice board for the whole
# building, instead of 8 separate sticky notes taped to 8 different doors.
# Change a password here once, and every container that needs it picks up
# the new value the next time you run "docker compose up".
#
# IMPORTANT: this file should NEVER be committed to git (it's already
# covered by the root .gitignore's ".env" and ".env.*" rules) since it
# will contain real secrets once you fill in EMAIL_PASS and JWT_SECRET below.

# MySQL root password — used by ALL 5 backend services to connect
    MYSQL_ROOT_PASSWORD=root

    # JWT signing secret — used ONLY by auth-service, but every other service
    # trusts tokens signed with this same secret. Generate a real one with:
    #   openssl rand -base64 32
    JWT_SECRET=NVazzNbQwRyuzwxPEa/AQ0v7YPdMW/Ddjs7y/mFqUS8=

    # Email sending (Notification Service) — leave EMAIL_ENABLED=false to just
    # log emails to the console instead of actually sending them
    EMAIL_ENABLED=false
    EMAIL_HOST=smtp.gmail.com
    EMAIL_PORT=587
    EMAIL_USER=
    EMAIL_PASS=
    EMAIL_FROM=ShopFlow <noreply@shopflow.com>

